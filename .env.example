# Copy this file to .env and replace every placeholder before starting the Web UI.
# Keep .env local; it is intentionally ignored by Git.
CAD_ADMIN_USERNAME=sz2026
CAD_ADMIN_PASSWORD=replace-with-a-strong-admin-password
CAD_SESSION_SECRET=replace-with-a-long-random-session-signing-secret
# JSON object: ordinary username -> password.  These users can only download release DXF.
CAD_OPERATOR_ACCOUNTS_JSON='{"operator_1":"replace-with-an-operator-password"}'
# Optional second JSON object for locally added ordinary users.
CAD_ADDITIONAL_OPERATOR_ACCOUNTS_JSON='{}'
# Completed Web tasks are deleted after this many days.
CAD_TASK_RETENTION_DAYS=30
# Optional absolute path to AcCoreConsole. AutoCAD 2024 for macOS is auto-detected.
CAD_AUTOCAD_CORE_CONSOLE=
# Use true after the API is served over HTTPS.
CAD_COOKIE_SECURE=false
