# Optional local development overrides. The desktop application has one local
# administrator and does not store usernames, passwords, tokens, or sessions.

# Source mode keeps output/web_tasks by default. Set this only to test another data root.
CAD_APP_DATA_ROOT=

# Optional absolute path to the locally installed AcCoreConsole executable.
CAD_AUTOCAD_CORE_CONSOLE=

# Completed tasks are retained for 30 days by default.
CAD_TASK_RETENTION_DAYS=30
