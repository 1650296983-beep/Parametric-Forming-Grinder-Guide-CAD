{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forming Grinder CAD",
  "version": "1.0.0",
  "identifier": "com.forminggrinder.guidecad",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* https://github.com https://objects.githubusercontent.com; img-src 'self' asset: http://127.0.0.1:* data:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "成型磨导轨 CAD 参数化生成器",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 720,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../dist/forming_grinder_cad_sidecar": "sidecar"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/1650296983-beep/Parametric-Forming-Grinder-Guide-CAD/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzMjYzQ0IzMTg4QkY3NUMKUldSYzk0c1lZendtOHlGYUxBUEtvQnVsNkxDTmtrcVZ0L2hsMk5nUnlZa010SXVFR2dTUUM1UnQK"
    }
  }
}
